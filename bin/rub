#!/usr/bin/env python3
import sys
import os
import yaml
import argparse
import subprocess

def main():
    parser = argparse.ArgumentParser(description="Rub an artifact with WHAT, WHY, SCOPE")
    parser.add_argument("target_id", help="The Target ID")
    parser.add_argument("field", nargs="?", help="Legacy positional field")
    parser.add_argument("content", nargs="?", help="Legacy positional content")
    parser.add_argument("--type", choices=["todo", "commission"], default="todo", help="The type of artifact being rubbed")
    parser.add_argument("--what", help="The WHAT field content")
    parser.add_argument("--why", help="The WHY field content")
    parser.add_argument("--scope", help="The SCOPE field content")
    
    # Parse known args so that if --what etc are not provided, we can still parse legacy
    args, _ = parser.parse_known_args()
    
    target_id = args.target_id
    artifact_type = args.type + "s" # e.g. todos, commissions
    artifact_dir = f"artifacts/{artifact_type}"
    target_file = f"{artifact_dir}/{target_id}.yml"
    
    os.makedirs(artifact_dir, exist_ok=True)
    
    if not os.path.exists(target_file):
        if args.type == "todo":
            print(f"ERROR: Todo ID {target_id} not found.")
            sys.exit(1)
        else:
            # Commissions may not have an initial artifact state file yet, auto-init
            data = {target_id: {"status": "UNRUBBED", "rub_matrix": {"what": None, "why": None, "scope": None}}}
    else:
        with open(target_file, "r") as f:
            data = yaml.safe_load(f) or {}
            
    target = data.get(target_id, {})
    
    # Handle old schema migration automatically
    if "rub_matrix" not in target:
        target["raw_thought"] = target.get("intent", "")
        target["rub_matrix"] = {"what": None, "why": None, "scope": None}
        target["status"] = "UNRUBBED"
        if "intent" in target:
            del target["intent"]

    updates = {}
    if args.field and args.content:
        # Avoid treating flags like --what as positional field
        if not args.field.startswith("--"):
            field = args.field.lower()
            if field not in ["what", "why", "scope"]:
                print(f"ERROR: Invalid field '{field}'. Must be what, why, or scope.")
                sys.exit(1)
            updates[field] = args.content
        else:
            print(f"ERROR: Invalid field '{args.field}'. Must be what, why, or scope.")
            sys.exit(1)
            
    if args.what:
        updates["what"] = args.what
    if args.why:
        updates["why"] = args.why
    if args.scope:
        updates["scope"] = args.scope
        
    for k, v in updates.items():
        target["rub_matrix"][k] = v
        
    matrix = target["rub_matrix"]
    if matrix["what"] and matrix["why"] and matrix["scope"]:
        target["status"] = "RUBBED"
        
    with open(target_file, "w") as f:
        yaml.dump({target_id: target}, f, default_flow_style=False, sort_keys=False)
        
    if updates:
        keys_updated = ", ".join(k.upper() for k in updates.keys())
        print(f"[RUB] Successfully updated {keys_updated} for {target_id}. Status: {target['status']}")

    if target.get("status") == "RUBBED":
        if args.type == "todo":
            print(f"[RUB] Automatically converting {target_id} to DAG node...")
            res = subprocess.run(["./bin/node", "convert-todo", target_id])
            if res.returncode != 0:
                print(f"[RUB] ERROR: Auto-convert failed with exit code {res.returncode}")
                sys.exit(res.returncode)
        elif args.type == "commission":
            print(f"[RUB] Commission {target_id} is now syntactically RUBBED.")
            print("\n🚨 CSI GUARD: INTENT VERIFICATION 🚨")
            print("[STEERING VECTOR] The syntactic Rub Matrix is populated, but the Commissionee Mandate requires SEMANTIC evaluation.")
            print("The Agent MUST now cognitively load the Commission Protocol invariants (`kb/commission_protocol_commissionee.md`) and pressure-test the 'WHY'.")
            print("If the intent is ambiguous or weak, the Agent MUST challenge the upstream issuer. Do NOT proceed to implementation until semantic fidelity is proven.")

if __name__ == "__main__":
    main()

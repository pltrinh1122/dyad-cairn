#!/usr/bin/env python3
import sys
import os
import datetime

def main():
    if len(sys.argv) < 2:
        print("Usage: ./bin/todo <intent>")
        sys.exit(1)
        
    intent = sys.argv[1]
    todo_dir = "dyad-state"
    os.makedirs(todo_dir, exist_ok=True)
    todo_path = os.path.join(todo_dir, "todos.md")
    
    timestamp = datetime.datetime.utcnow().isoformat() + "Z"
    
    with open(todo_path, "a") as f:
        f.write(f"- **{timestamp}** | {intent}\n")
        
    print(f"[TODO] Successfully parked todo: {intent}")

if __name__ == "__main__":
    main()

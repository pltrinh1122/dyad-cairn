#!/usr/bin/env python3
import sys
import os
import yaml
import datetime

def append_todo(intent):
    # Log to the Ledger
    sys.path.append('.')
    from skills import ledger_manager
    ledger_manager.append_ledger("todo", intent)

    todo_dir = "artifacts"
    os.makedirs(todo_dir, exist_ok=True)
    todo_yml = os.path.join(todo_dir, "todos.yml")
    todo_md = os.path.join(todo_dir, "todos.md")
    
    timestamp = datetime.datetime.utcnow().isoformat() + "Z"
    todo_id = f"todo_{int(datetime.datetime.utcnow().timestamp())}"
    
    # Update YAML
    if os.path.exists(todo_yml):
        with open(todo_yml, "r") as f:
            todos = yaml.safe_load(f) or {}
    else:
        todos = {}
        
    if "backlog" not in todos:
        todos["backlog"] = {}
        
    todos["backlog"][todo_id] = {
        "raw_thought": intent,
        "timestamp": timestamp,
        "rub_matrix": {
            "what": None,
            "why": None,
            "scope": None
        },
        "status": "UNRUBBED"
    }
    
    with open(todo_yml, "w") as f:
        yaml.dump(todos, f, default_flow_style=False, sort_keys=False)
        
    # Project Markdown View
    with open(todo_md, "w") as f:
        f.write("# Todo Backlog (Pre-DAG Holding Pen)\n\n")
        f.write("> Ideas parked here have not formally entered the SPAOR execution loop.\n")
        f.write("> Use `./bin/node convert-todo <todo_id>` to ingest an item into the DAG.\n\n")
        
        for tid, data in todos["backlog"].items():
            intent_str = data.get('raw_thought', data.get('intent', ''))
            status = data.get('status', 'LEGACY')
            f.write(f"### {tid} [{status}]\n")
            f.write(f"**Raw Thought:** {intent_str}\n\n")
            
            matrix = data.get('rub_matrix', {})
            what_status = "[x]" if matrix.get("what") else "[ ]"
            why_status = "[x]" if matrix.get("why") else "[ ]"
            scope_status = "[x]" if matrix.get("scope") else "[ ]"
            
            f.write(f"**The Rub Matrix:**\n")
            f.write(f"- {what_status} **WHAT:** {matrix.get('what') or 'Missing'}\n")
            f.write(f"- {why_status} **WHY:** {matrix.get('why') or 'Missing'}\n")
            f.write(f"- {scope_status} **SCOPE:** {matrix.get('scope') or 'Missing'}\n\n")
            f.write("---\n")
            
    print(f"[TODO] Successfully parked todo in holding pen: {intent}")
    print(f"[TODO] ID: {tid}")

def main():
    if len(sys.argv) < 2:
        print("Usage: ./bin/todo <intent>")
        sys.exit(1)
        
    intent = sys.argv[1]
    append_todo(intent)

if __name__ == "__main__":
    main()

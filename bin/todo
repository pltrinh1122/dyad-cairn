#!/usr/bin/env python3
import sys
import os
import yaml
import datetime
import uuid

def append_todo(intent, status="UNRUBBED"):
    # Log to the Ledger
    sys.path.append('.')
    from skills import ledger_manager
    ledger_manager.append_ledger("todo", intent)

    todo_dir = "artifacts/todos"
    os.makedirs(todo_dir, exist_ok=True)
    todo_md = os.path.join("artifacts", "todos.md")
    
    now = datetime.datetime.now(datetime.timezone.utc)
    timestamp = now.isoformat()
    if timestamp.endswith('+00:00'):
        timestamp = timestamp[:-6] + "Z"
    if not timestamp.endswith('Z'):
        timestamp += 'Z'
    uuid_segment = uuid.uuid4().hex[:8]
    todo_id = f"todo_{now.timestamp()}_{uuid_segment}"
    
    # Update YAML
    todo_file = os.path.join(todo_dir, f"{todo_id}.yml")
    data = {
        todo_id: {
            "raw_thought": intent,
            "timestamp": timestamp,
            "rub_matrix": {
                "what": None,
                "why": None,
                "scope": None
            },
            "status": status
        }
    }
    with open(todo_file, "w") as f:
        yaml.dump(data, f, default_flow_style=False, sort_keys=False)
        
    todos = {"backlog": {}}
    if os.path.exists(todo_dir):
        for fname in sorted(os.listdir(todo_dir)):
            if fname.endswith(".yml"):
                with open(os.path.join(todo_dir, fname), "r") as file_obj:
                    d = yaml.safe_load(file_obj) or {}
                    for k, v in d.items():
                        todos["backlog"][k] = v
        
    # Project Markdown View
    with open(todo_md, "w") as f:
        f.write("# Todo Backlog (Pre-DAG Holding Pen)\n\n")
        f.write("> Ideas parked here have not formally entered the SPAOR execution loop.\n")
        f.write("> Use `./bin/node convert-todo <todo_id>` to ingest an item into the DAG.\n\n")
        
        for tid, data in todos["backlog"].items():
            intent_str = data.get('raw_thought', data.get('intent', ''))
            status = data.get('status', 'LEGACY')
            f.write(f"### {tid} [{status}]\n")
            f.write(f"**Raw Thought:** {intent_str}\n\n")
            
            matrix = data.get('rub_matrix', {})
            what_status = "[x]" if matrix.get("what") else "[ ]"
            why_status = "[x]" if matrix.get("why") else "[ ]"
            scope_status = "[x]" if matrix.get("scope") else "[ ]"
            
            f.write(f"**The Rub Matrix:**\n")
            f.write(f"- {what_status} **WHAT:** {matrix.get('what') or 'Missing'}\n")
            f.write(f"- {why_status} **WHY:** {matrix.get('why') or 'Missing'}\n")
            f.write(f"- {scope_status} **SCOPE:** {matrix.get('scope') or 'Missing'}\n\n")
            f.write("---\n")
            
    print(f"[TODO] Successfully parked todo in holding pen: {intent}")
    print(f"[TODO] ID: {tid}")

def main():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("intent", help="The intent for the todo")
    parser.add_argument("--status", default="UNRUBBED", help="The status of the todo")
    args = parser.parse_args()
        
    append_todo(args.intent, args.status)

if __name__ == "__main__":
    main()

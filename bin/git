#!/bin/bash
# Mock layer for git to decouple from host environment resolution
# and enforce Dyad ABAC Sandbox permissions dynamically.

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
python3 "$DIR/../skills/sandbox_enforcer.py" git "$@"
if [ $? -ne 0 ]; then
    exit 1
fi

exec /usr/bin/git "$@"

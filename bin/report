#!/usr/bin/env python3
import json
import os
import sys

def main():
    if len(sys.argv) < 2 or sys.argv[1] != "executed":
        print("Usage: ./bin/report executed")
        sys.exit(1)
        
    ledger_path = "dyad-state/ledger.jsonl"
    if not os.path.exists(ledger_path):
        print("No ledger found.")
        return

    manual = []
    autonomous = []

    with open(ledger_path, "r") as f:
        for line in f:
            if not line.strip(): continue
            try:
                data = json.loads(line)
            except:
                continue
            if data.get("action") == "NODE-RETRO":
                msg = data.get("message", "")
                if "[node_" in msg:
                    parts = msg.split("]", 1)
                    node_id = parts[0].strip("[")
                    content = parts[1].strip()
                    
                    entry = f"- {node_id}: {content}"
                    
                    if "[TRIGGER: autonomous]" in msg or "[TRIGGER: daemon]" in msg or "batch_exec_event" in msg:
                        autonomous.append(entry)
                    else:
                        manual.append(entry)
                        
    print("================================================================================")
    print("📋 [MECHANICAL UI PRESENTATION: EXECUTION REPORT]")
    print("================================================================================")
    print("### AUTONOMOUS EXECUTIONS (Daemon/Cron/Batch)")
    if autonomous:
        for a in autonomous:
            print(a)
    else:
        print("└── (none)")
        
    print("\n### MANUAL EXECUTIONS (Operator Steered / Lean)")
    if manual:
        for m in manual:
            print(m)
    else:
        print("└── (none)")
    print("================================================================================")

if __name__ == "__main__":
    main()

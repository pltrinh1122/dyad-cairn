#!/usr/bin/env python3
import os
import json
import fcntl
import subprocess

def main():
    queue_file = "dyad-state/sync_queue.jsonl"
    if not os.path.exists(queue_file):
        print("Sync queue is empty.")
        return

    items = []
    # Atomically read and clear the queue
    with open(queue_file, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        lines = f.readlines()
        for line in lines:
            line = line.strip()
            if line:
                items.append(json.loads(line))
        f.seek(0)
        f.truncate()
        fcntl.flock(f, fcntl.LOCK_UN)

    if not items:
        print("Sync queue is empty.")
        return

    print(f"Found {len(items)} items in the sync queue. Pushing to DAG Rack via todo...")
    
    for item in items:
        intent = item.get("intent")
        status = item.get("status", "UNRUBBED")
        if intent:
            cmd = ["./bin/todo", intent, "--status", status]
            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode != 0:
                print(f"Error executing todo for intent: {intent}")
                print(result.stderr)
            else:
                print(f"Successfully processed: {intent}")

if __name__ == "__main__":
    main()

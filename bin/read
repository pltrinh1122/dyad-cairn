#!/bin/bash
if [ "$1" == "frontier" ]; then
    python3 skills/frontier_reader.py
elif [ "$1" == "guards" ] || [ "$1" == "arm/disarm" ]; then
    python3 skills/guards_reader.py
elif [ "$1" == "todo" ] || [ "$1" == "rack" ]; then
    python3 skills/todo_reader.py
elif [ "$1" == "quarries" ]; then
    python3 skills/quarry_reader.py
else
    echo "Usage: ./bin/read <frontier|guards|todo|quarries>"
    exit 1
fi
